# ════════════════════════════════════════════════
#   إعدادات بوت العروض — انسخ هذا الملف إلى .env
#   وأملأ القيم الخاصة بك
# ════════════════════════════════════════════════

# ── تيليجرام ──────────────────────────────────
# من my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# من @BotFather بعد /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ── القنوات ────────────────────────────────────
# القناة اللي هتستقبل العروض (قناتك الخاصة)
DEST_CHANNEL=@my_private_deals

# القنوات اللي هتراقبها — افصل بفاصلة
SOURCE_CHANNELS=@amazon_deals_ar,@noon_offers,@jumia_egypt_deals,@tech_offers_sa

# ── Claude AI ─────────────────────────────────
# من console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxx

# ── إعدادات الفلترة ────────────────────────────
# أقل نسبة خصم تقبلها (0 = كل العروض)
MIN_DISCOUNT=15
